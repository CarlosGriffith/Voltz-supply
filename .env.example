# Copy to .env and fill in. Used by: npm run dev:api, npm run dev:full, db:* scripts.
# Do not commit .env. For Netlify, set the same AIVEN_* values in the site Environment UI.
# See NETLIFY.md for deploy + npm run netlify:sync-blobs (product images).

AIVEN_MYSQL_HOST=mysql-xxxxx.a.aivencloud.com
AIVEN_MYSQL_PORT=28070
AIVEN_MYSQL_USER=avnadmin
AIVEN_MYSQL_PASSWORD=
AIVEN_MYSQL_DATABASE=defaultdb

# Optional: path to Aiven CA PEM (default: scripts/aiven-ca.pem when file exists)
# AIVEN_CA_PATH=

# Optional: PEM contents or path to PEM file (overrides default CA discovery)
# AIVEN_MYSQL_SSL_CA=

# Optional: ms (default 30000)
# AIVEN_MYSQL_CONNECT_TIMEOUT_MS=30000

# Optional: set to 1 only for local MySQL without TLS (not for Aiven)
# AIVEN_MYSQL_SSL_DISABLE=1

# ── One-time: Supabase (Postgres) → Aiven MySQL CMS migration (npm run db:migrate:supabase)
# SUPABASE_DATABASE_URL=postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres
# Optional: SUPABASE_PG_SSL_DISABLE=1 for local Postgres only

# Vite: leave empty locally and on Netlify so /api is proxied (dev) or uses same origin (prod).
# Do not set VITE_API_URL=http://127.0.0.1:3001 unless you must — it forces cross-origin calls and
# breaks if you open the site via localhost, a LAN IP, or another hostname.
# VITE_API_URL=

# Optional: SMTP tuning when the API runs on Render/cloud (connection timeouts)
# On Render, IPv4 + ipv4first DNS are default; set SMTP_USE_IPV6=1 only if you need IPv6.
# SMTP_FORCE_IPV4=1
# SMTP_USE_IPV6=1
# SMTP_CONNECTION_TIMEOUT_MS=45000
# SMTP_SOCKET_TIMEOUT_MS=60000

# One-time: push local server/uploads → Netlify Blobs (npm run netlify:sync-blobs)
# NETLIFY_SITE_ID=
# NETLIFY_AUTH_TOKEN=